# ---- required ----
TOKEN=                              # Discord Bot Token. Enable MESSAGE CONTENT and SERVER MEMBERS intents in the Discord Developer Portal.
ANNOUNCEMENT_CHANNEL=               # Channel ID where the bot watches for CTF announcement messages. Must be a text/announcement channel.
GENERAL_CATEGORY=                   # Category channel ID. New CTF categories are created right above this one.
FULL_MEMBER_ROLE_ID=                # Role ID allowed to use /announce and /delete, and granted view on every CTF category.
PLAYER_ROLE=                        # Role ID(s) allowed to join a CTF by reacting ✅. Comma-separated to allow multiple (subteams).
BASE_PATH=/app/dbs/                 # Directory where the SQLite database (fluxbot.db) lives. Keep as-is when using docker-compose.
PAD_URL=https://demo.hedgedoc.org   # HedgeDoc v1 instance, no trailing slash.

# ---- optional ----
PAD_USERNAME=                       # Optional HedgeDoc login email (only if your instance requires auth).
PAD_PASSWORD=                       # Optional HedgeDoc login password.
SOLVED_EMOTES=🍉                    # Comma-separated emotes used on /solved (one chosen at random). Supports unicode and custom Discord emotes (<:Name:id>).
NEWBIE_REACTED_ERROR=               # Override the DM sent to users without the player role who react to a CTF announcement.
BOT_LANG=en                         # Bot UI language: en (default) or de.

# ---- CTFtime feed (optional) ----
# Leave CTFTIME_FEED_CHANNEL unset to disable the entire feature.
CTFTIME_FEED_CHANNEL=               # Channel ID for the CTFtime upcoming-CTFs feed (one embed per slot).
CTFTIME_FEED_AMOUNT=10              # Number of CTF slots to maintain in the feed channel.
CTFTIME_POINTS_MIN=0                # Minimum CTFtime weight (points) for a CTF to appear in the feed.
CTFTIME_INCLUDE_ONSITE=false        # If "true", include onsite CTFs; otherwise online only.
